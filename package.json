{
  "name": "neo-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:next": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "clean": "npx rimraf .next",
    "free-port": "npx kill-port 3000",
    "db:link": "supabase link --project-ref hokibyfaompjhdhnhtru",
    "db:pull": "supabase db pull --project-id hokibyfaompjhdhnhtru",
    "db:push": "supabase db push --linked",
    "db:types": "supabase gen types typescript --project-id hokibyfaompjhdhnhtru > src/core/types/database.types.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "test": "vitest run",
    "test:watch": "vitest",
    "impecable": "npm run lint && npm run typecheck && npm run format",
    "insights": "node scripts/speed-insights.js",
    "insights:ci": "node scripts/speed-insights.js https://neo.app"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "mercadopago": "^3.1.0",
    "next": "^16.2.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "react-icons": "^5.6.0",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.5",
    "supabase": "^2.100.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
